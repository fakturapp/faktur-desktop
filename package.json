{
  "name": "faktur-desktop",
  "version": "2.4.3",
  "description": "Client de bureau Faktur — OAuth2 + coffre-fort chiffré",
  "author": {
    "name": "danbenba",
    "email": "support@fakturapp.cc"
  },
  "main": "src/main/main.js",
  "type": "commonjs",
  "license": "MIT",
  "scripts": {
    "start": "node scripts/compile-env.js && electron .",
    "start:dev": "node scripts/compile-env.js && cross-env FAKTUR_ENV=development electron .",
    "cleanup": "node scripts/cleanup.js",
    "cleanup:all": "node scripts/cleanup.js --dist",
    "cleanup:dry": "node scripts/cleanup.js --dry",
    "compile-env": "node scripts/compile-env.js",
    "generate-icon": "node scripts/generate-icon.js",
    "prebuild": "node scripts/generate-icon.js && node scripts/compile-env.js",
    "build": "node scripts/generate-icon.js && node scripts/compile-env.js && electron-builder",
    "build:win": "node scripts/generate-icon.js && node scripts/compile-env.js && electron-builder --win",
    "build:mac": "node scripts/generate-icon.js && node scripts/compile-env.js && electron-builder --mac",
    "build:linux": "node scripts/generate-icon.js && node scripts/compile-env.js && electron-builder --linux",
    "generate:signing-key": "node scripts/generate-signing-key.js",
    "test": "node tests/desktop_proof.test.js && node tests/attestation.test.js && node tests/updater_platform.test.js",
    "lint": "echo \"lint placeholder\""
  },
  "build": {
    "appId": "cc.fakturapp.desktop",
    "productName": "Faktur Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.md",
      "!**/.env*",
      "!tests/**/*",
      "!scripts/**/*"
    ],
    "asar": true,
    "asarUnpack": [],
    "afterPack": "scripts/afterPack.js",
    "extraResources": [],
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "FakturDesktop-Installer.exe",
      "allowToChangeInstallationDirectory": false
    },
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": false,
      "onlyLoadAppFromAsar": true,
      "loadBrowserProcessSpecificV8Snapshot": false,
      "grantFileProtocolExtraPrivileges": true
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        },
        {
          "target": "zip",
          "arch": "universal"
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.business",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "FakturDesktop-mac.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": "x64"
        }
      ],
      "icon": "build/icon.png",
      "category": "Office",
      "artifactName": "FakturDesktop-linux-${arch}.${ext}"
    },
    "protocols": [
      {
        "name": "Faktur",
        "schemes": [
          "faktur"
        ]
      }
    ]
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^35.0.1",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "dotenv": "^16.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fakturapp/faktur-desktop.git"
  }
}