{
  "name": "faktur-app",
  "version": "1.0.0",
  "description": "Application Electron pour Faktur - Logiciel de facturation",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.faktur.app",
    "productName": "Faktur",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      ".env",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^35.0.1",
    "electron-builder": "^26.0.12",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "dotenv": "^16.5.0"
  }
}
