# Faktur Desktop — environment template
# Copy to `.env` and fill in with the values generated from the admin panel
# at https://dash.fakturapp.cc/dashboard/admin/oauth-apps

# --- OAuth client credentials ----------------------------------------------
# Issued once when the admin creates the OAuth app via the panel. The raw
# secret is shown ONE TIME ONLY — copy it immediately into this file.
FAKTUR_OAUTH_CLIENT_ID=
FAKTUR_OAUTH_CLIENT_SECRET=

# --- Endpoints -------------------------------------------------------------
# Public Faktur instance. Override for self-hosted deployments.
FAKTUR_API_BASE_URL=https://api.fakturapp.cc
FAKTUR_API_PREFIX=/api/v1
FAKTUR_DASHBOARD_URL=https://dash.fakturapp.cc
FAKTUR_AUTHORIZE_URL=https://dash.fakturapp.cc/oauth/authorize

# --- Scopes requested by the desktop client --------------------------------
# Space-separated list. Must be a subset of the scopes granted to the app.
FAKTUR_OAUTH_SCOPES=profile invoices:read invoices:write clients:read clients:write vault:unlock offline_access

# --- Loopback callback -----------------------------------------------------
# The desktop app binds to 127.0.0.1 on an ephemeral port, but you can
# pin a specific port range here if your firewall policy needs it.
FAKTUR_CALLBACK_HOST=127.0.0.1
FAKTUR_CALLBACK_PATH=/callback
# Leave 0 for auto-assigned port.
FAKTUR_CALLBACK_PORT=0

# --- Developer toggles -----------------------------------------------------
FAKTUR_ENV=production
FAKTUR_DEVTOOLS=false
